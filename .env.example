APP_NAME="Laravel Admin System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Taipei
APP_URL=http://localhost

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admin_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Analytics
ANALYTICS_VIEW_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# SEO 設定
SEO_DEFAULT_TITLE="${APP_NAME}"
SEO_DEFAULT_DESCRIPTION="通用後台管理系統"
SEO_DEFAULT_KEYWORDS="laravel,admin,cms"
SEO_ENABLE_SITEMAP=true
SEO_ENABLE_ROBOTS=true

# Admin 設定
ADMIN_PREFIX=admin
ADMIN_PER_PAGE=15
ADMIN_SESSION_TIMEOUT=120

# 檔案上傳設定
UPLOAD_MAX_SIZE=10240
UPLOAD_ALLOWED_MIMES=jpg,jpeg,png,gif,pdf,doc,docx

# Telescope (僅在本地環境啟用，正式環境務必設為 false)
TELESCOPE_ENABLED=true

# 部署用 Token（用於 /deploy/migrate, /deploy/seed 等路由）
# 正式環境請設定一組隨機 token，例如: openssl rand -hex 32
DEPLOY_TOKEN=
